# 只需配置此文件（apikey）即可完美运行你的私人Claude Code
# ============================================================
#大模型api配置信息（若通过 LiteLLM 代理，则需先配置 litellm_config.yaml，然后启动 LiteLLM）
# litellm启动方式（命令行运行）: litellm --config litellm_config.yaml --port 4000
# ============================================================
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=http://localhost:4000 or https://api.anthropic.com
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
API_TIMEOUT_MS=3000000

# ============================================================
# 通用设置（建议始终开启）
# ============================================================
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
